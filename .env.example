# Neon PostgreSQL connection string (with PostGIS enabled)
DATABASE_URL=

# NPS Developer API key — https://www.nps.gov/subjects/developer/get-started.htm
NPS_API_KEY=

# (Optional) WeatherAPI.com key for live weather in park popups — https://www.weatherapi.com/
WEATHER_API_KEY=

# (Optional) Stadia Maps API key for the Outdoors basemap — https://stadiamaps.com/
NEXT_PUBLIC_STADIA_API_KEY=

# (Optional) Secret to protect the /api/cron/sync-parks endpoint (required on Vercel)
CRON_SECRET=
